date.timezone = UTC
memory_limit = 512M
upload_max_filesize = 128M
post_max_size = 128M
max_execution_time = 120

display_errors = On
display_startup_errors = On
error_reporting = E_ALL
log_errors = On

opcache.enable = 1
opcache.enable_cli = 1
opcache.validate_timestamps = 1
opcache.revalidate_freq = 0
